#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

echo "Running pre-commit checks..."

if [ -f "$repo_root/backend/.venv/bin/activate" ]; then
  # Preferred when the backend virtualenv lives inside the repo.
  # shellcheck disable=SC1091
  . "$repo_root/backend/.venv/bin/activate"
elif [ -f "$repo_root/../tez-ielts-backend/.venv/bin/activate" ]; then
  # Temporary fallback for the current local machine.
  # shellcheck disable=SC1091
  . "$repo_root/../tez-ielts-backend/.venv/bin/activate"
fi

cd "$repo_root/frontend"
npm run format:check
npm run lint

cd "$repo_root/backend"
ruff check .
bandit -q -r core usr evl main.py
