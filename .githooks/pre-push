#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

echo "Running pre-push checks..."

if [ -f "$repo_root/backend/.venv/bin/activate" ]; then
  # shellcheck disable=SC1091
  . "$repo_root/backend/.venv/bin/activate"
elif [ -f "$repo_root/../tez-ielts-backend/.venv/bin/activate" ]; then
  # shellcheck disable=SC1091
  . "$repo_root/../tez-ielts-backend/.venv/bin/activate"
fi

cd "$repo_root/frontend"
npm run test:unit

cd "$repo_root/backend"
pytest -q

if command -v docker >/dev/null 2>&1; then
  docker build -t tez-ielts-backend:prepush "$repo_root/backend" >/dev/null
fi
